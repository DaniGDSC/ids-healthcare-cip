  "device_tiers": {
    "life_sustaining": 1.0,
    "vital_monitoring": 0.8,
    "diagnostic": 0.5,
    "auxiliary": 0.3
  },
  "data_sensitivity": {
    "phi_realtime": 1.0,
    "phi_stored": 0.7,
    "device_telemetry": 0.4,
    "non_sensitive": 0.1
  },
  "cia_threats": {
    "Spoofing": {
      "C": 0.6,
      "I": 0.9,
      "A": 0.3
